# =============================================================================
# Ventia Staging — Environment Variables
# Copy to .env and fill in the values
# =============================================================================

# --- Database ---
POSTGRES_DB=ventia_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# --- Backend (FastAPI) ---
ENVIRONMENT=staging
LOG_LEVEL=info
SECRET_KEY=CHANGE_ME_RANDOM_STRING

# Auth0
AUTH0_DOMAIN=dev-xxxxx.us.auth0.com
AUTH0_AUDIENCE=https://api.ventia-latam.com
AUTH0_ISSUER=https://dev-xxxxx.us.auth0.com/
AUTH0_ALGORITHM=RS256
AUTH0_CONNECTION=Username-Password-Authentication

# Auth0 Management API (for user creation)
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
AUTH0_MANAGEMENT_AUDIENCE=https://dev-xxxxx.us.auth0.com/api/v2/

# CORS
CORS_ORIGINS=["https://staging.ventia-latam.com"]

# Webhooks
WEBHOOK_BASE_URL=https://staging-api.ventia-latam.com

# eFact (electronic invoicing — optional for staging)
EFACT_BASE_URL=
EFACT_RUC_VENTIA=
EFACT_PASSWORD_REST=

# n8n (reminder workflows)
N8N_BASE_URL=https://n8n.ventia-latam.com
N8N_API_KEY=

# Resend (email — optional for staging)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=https://staging-api.ventia-latam.com/api/v1
NEXT_PUBLIC_MESSAGING_WS_URL=wss://staging-ws.ventia-latam.com/cable

# Auth0 (frontend — public)
NEXT_PUBLIC_AUTH0_DOMAIN=dev-xxxxx.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=CHANGE_ME
NEXT_PUBLIC_AUTH0_AUDIENCE=https://api.ventia-latam.com

# Auth0 (frontend — server-side)
AUTH0_SECRET=CHANGE_ME_RANDOM_32_BYTES
AUTH0_BASE_URL=https://staging.ventia-latam.com
AUTH0_ISSUER_BASE_URL=https://dev-xxxxx.us.auth0.com
AUTH0_CLIENT_ID=CHANGE_ME
AUTH0_CLIENT_SECRET=CHANGE_ME

# IMPORTANT: Also configure in Auth0 Dashboard:
# - Allowed Callback URLs: https://staging.ventia-latam.com/api/auth/callback
# - Allowed Logout URLs: https://staging.ventia-latam.com
# - Allowed Web Origins: https://staging.ventia-latam.com

# WhatsApp Embedded Signup (frontend — Meta SDK)
NEXT_PUBLIC_WHATSAPP_APP_ID=
NEXT_PUBLIC_WHATSAPP_CONFIGURATION_ID=

# Firebase (push notifications — optional for staging)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# --- Messaging (Rails) ---
RAILS_ENV=development
SECRET_KEY_BASE=CHANGE_ME_RANDOM_STRING
MESSAGING_CORS_ORIGINS=https://staging.ventia-latam.com
FRONTEND_URL=https://staging.ventia-latam.com

# Internal service-to-service auth (backend FastAPI ↔ messaging Rails)
# Generar con: openssl rand -hex 32
MESSAGING_SERVICE_API_KEY=CHANGE_ME_RANDOM_STRING

# WhatsApp / Meta (for WhatsApp integration)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
WHATSAPP_CLOUD_BASE_URL=https://graph.facebook.com

# Firebase Admin (messaging push notifications)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=""

# --- Sentry (Error Monitoring) ---
SENTRY_BACKEND_DSN=
SENTRY_MESSAGING_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
