# =============================================================================
# Ventia Production — Environment Variables
# Copy to .env and fill in the values
# =============================================================================

# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME

# --- Backend (FastAPI) ---
LOG_LEVEL=info
SECRET_KEY=CHANGE_ME_RANDOM_STRING
CORS_ORIGINS=["https://ventia-latam.com"]

# Auth0
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_ISSUER=
AUTH0_ALGORITHM=RS256
AUTH0_CONNECTION=Username-Password-Authentication
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
AUTH0_MANAGEMENT_AUDIENCE=

# Webhooks
WEBHOOK_BASE_URL=https://api.ventia-latam.com

# Messaging service connection (internal Docker network)
MESSAGING_SERVICE_API_KEY=CHANGE_ME_RANDOM_STRING

# eFact (electronic invoicing)
EFACT_BASE_URL=
EFACT_RUC_VENTIA=
EFACT_PASSWORD_REST=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Docker Images ---
BACKEND_IMAGE=equipoventia/ventia-backend:latest
MESSAGING_IMAGE=equipoventia/ventia-messaging:1.0.0
FRONTEND_IMAGE=equipoventia/ventia-frontend:latest

# --- Frontend (Next.js) — variables de RUNTIME (las NEXT_PUBLIC_* van horneadas en la imagen) ---
AUTH0_BASE_URL=https://ventia-latam.com
# Auth0 de la app FRONTEND (Regular Web App; nombres estándar del SDK @auth0/nextjs-auth0).
# El backend usa AUTH0_MANAGEMENT_CLIENT_ID/SECRET, así que no colisionan.
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=                   # generar con: openssl rand -hex 32
NEXT_PUBLIC_API_URL=https://api.ventia-latam.com/api/v1
NEXT_PUBLIC_MESSAGING_WS_URL=wss://ws.ventia-latam.com/cable
# GCS (uploads de tickets — server-side)
GCS_BUCKET_NAME=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=""
# Resend (Libro de Reclamaciones — server-side)
RECLAMACIONES_TO_EMAIL=

# --- n8n ---
N8N_ENCRYPTION_KEY=CHANGE_ME
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME
N8N_WEBHOOK_URL=https://n8n.ventia-latam.com
TIMEZONE=America/Lima

# n8n API (backend uses this for reminders)
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=CHANGE_ME

# --- Messaging (Rails) ---
SECRET_KEY_BASE=CHANGE_ME_RANDOM_64_CHARS
MESSAGING_CORS_ORIGINS=https://ventia-latam.com
MESSAGING_SERVICE_URL=https://ws.ventia-latam.com
FRONTEND_URL=https://ventia-latam.com

# WhatsApp / Meta
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
WHATSAPP_CLOUD_BASE_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v22.0

# Firebase Admin (push notifications)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=""

# --- Sentry (Error Monitoring) ---
SENTRY_BACKEND_DSN=
SENTRY_MESSAGING_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
