<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soporte humano requerido</title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #e2e8f0;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #e2e8f0; padding: 40px 16px;">
        <tr>
            <td align="center">
                <table width="560" cellpadding="0" cellspacing="0" style="max-width: 560px;">

                    <!-- Brand header -->
                    <tr>
                        <td style="padding: 0 0 24px 0;">
                            <span style="color: #184373; font-size: 20px; font-weight: 700; letter-spacing: 0.5px;">Vent<span style="color: #5ACAF0;">IA</span></span>
                        </td>
                    </tr>

                    <!-- Main card -->
                    <tr>
                        <td>
                            <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 1px 3px rgba(24,36,50,0.06), 0 8px 32px rgba(24,36,50,0.06);">

                                <!-- Alert accent bar -->
                                <tr>
                                    <td style="background: linear-gradient(90deg, #f59e0b, #f59e0b 40%, #5ACAF0); height: 4px; font-size: 0; line-height: 0;">&nbsp;</td>
                                </tr>

                                <!-- Badge + Title -->
                                <tr>
                                    <td style="padding: 36px 40px 0 40px;">
                                        <table cellpadding="0" cellspacing="0">
                                            <tr>
                                                <td style="background-color: #fef3c7; border-radius: 6px; padding: 6px 12px;">
                                                    <span style="color: #92400e; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px;">Soporte humano</span>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="padding: 16px 40px 0 40px;">
                                        <h1 style="margin: 0; color: #182432; font-size: 20px; font-weight: 700; line-height: 1.3;">
                                            <%= @contact_name %> necesita atención humana
                                        </h1>
                                        <p style="margin: 8px 0 0 0; color: #64748b; font-size: 14px; line-height: 1.5;">
                                            Se ha solicitado la intervención de un agente en esta conversación.
                                        </p>
                                    </td>
                                </tr>

                                <!-- Divider -->
                                <tr>
                                    <td style="padding: 24px 40px;">
                                        <table width="100%" cellpadding="0" cellspacing="0">
                                            <tr><td style="border-top: 1px solid #e2e8f0; font-size: 0; height: 1px;">&nbsp;</td></tr>
                                        </table>
                                    </td>
                                </tr>

                                <!-- Details -->
                                <tr>
                                    <td style="padding: 0 40px;">
                                        <table width="100%" cellpadding="0" cellspacing="0">
                                            <tr>
                                                <td width="50%" style="padding-bottom: 8px;">
                                                    <p style="margin: 0; color: #94a3b8; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">Cliente</p>
                                                    <p style="margin: 4px 0 0 0; color: #182432; font-size: 15px; font-weight: 600;"><%= @contact_name %></p>
                                                </td>
                                                <td width="50%" style="padding-bottom: 8px;">
                                                    <p style="margin: 0; color: #94a3b8; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; font-weight: 600;">Cuenta</p>
                                                    <p style="margin: 4px 0 0 0; color: #182432; font-size: 15px; font-weight: 600;"><%= @account_name %></p>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>

                                <!-- CTA -->
                                <tr>
                                    <td style="padding: 28px 40px 36px 40px;">
                                        <a href="<%= @conversation_url %>" style="display: inline-block; background-color: #182432; color: #ffffff; text-decoration: none; font-weight: 600; font-size: 14px; padding: 12px 28px; border-radius: 8px;">
                                            Abrir conversación &rarr;
                                        </a>
                                    </td>
                                </tr>

                            </table>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="padding: 28px 0 0 0; text-align: center;">
                            <p style="margin: 0; font-size: 12px; color: #94a3b8; line-height: 1.6;">
                                Notificación de soporte &middot; <span style="color: #184373; font-weight: 600;">Vent<span style="color: #5ACAF0;">IA</span></span>
                            </p>
                            <p style="margin: 4px 0 0 0; font-size: 11px; color: #cbd5e1;">
                                Puedes desactivar estas notificaciones desde la configuración de tu cuenta.
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>
</html>
