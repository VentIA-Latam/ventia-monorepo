# Rails Environment
RAILS_ENV=development
SECRET_KEY_BASE=your-secret-key-here-generate-with-rails-secret

# Database Configuration
# Para Docker: usa "postgres" como host
# Para local: usa "localhost" o "host.docker.internal"
POSTGRES_HOST=postgres
POSTGRES_PORT=5433  # Puerto externo (mapea a 5432 en el contenedor)
POSTGRES_PORT_INTERNAL=5432  # Puerto interno del contenedor
POSTGRES_DATABASE=messaging_db
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=messaging_password

# Redis Configuration (for Sidekiq and caching)
REDIS_PORT=6380  # Puerto externo (mapea a 6379 en el contenedor)
REDIS_URL=redis://redis:6379/1

# Server Configuration
MESSAGING_SERVICE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Internal service-to-service auth — debe coincidir con apps/backend/.env
# El backend FastAPI lo envía en header X-API-Key en cada request interna.
# Generar con: openssl rand -hex 32
MESSAGING_SERVICE_API_KEY=your_messaging_service_api_key_here

# Facebook / WhatsApp Cloud API
# Get these from Meta for Developers: https://developers.facebook.com
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# WhatsApp Cloud API
# These are stored per-tenant in the database, not here
# This is just for reference
# WHATSAPP_CLOUD_BASE_URL=https://graph.facebook.com

# Instagram Login (Business Login for Instagram)
# Get these from the Instagram product inside your Meta App (Add Product > Instagram).
# The app can be the SAME Meta App used for WhatsApp. The Instagram App ID/Secret
# are specific to the Instagram product (API setup with Instagram login section).
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
# Single app-level webhook verify token (configured once in the Meta dashboard).
# Generate with: openssl rand -hex 16
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-instagram-webhook-verify-token
# Public, HTTPS base URL of THIS messaging service. Used to build the OAuth
# redirect_uri ({MESSAGING_PUBLIC_URL}/instagram/callback) and must be registered
# in the Meta dashboard. In local dev use an ngrok URL.
MESSAGING_PUBLIC_URL=https://your-messaging-public-url
# Frontend base URL the OAuth callback redirects back to after connecting.
FRONTEND_URL=http://localhost:3000
# Optional: defaults to v22.0 (shared with WhatsApp)
# INSTAGRAM_API_VERSION=v22.0

# Logging
LOG_LEVEL=info
RAILS_LOG_TO_STDOUT=true

# Sentry (Error Monitoring — leave empty to disable)
SENTRY_DSN=
# Optional: override the environment tag sent to Sentry (defaults to Rails.env)
# SENTRY_ENVIRONMENT=staging

# Resend (Transactional email — used by NotificationMailer for human_support
# and payment_review notifications). Only required in production; development
# uses letter_opener to intercept emails locally.
# Get the API key from https://resend.com/api-keys
RESEND_API_KEY=
# Sender address. Must be a verified domain in your Resend account in production.
# Defaults to noreply@ventia.pe if unset.
RESEND_FROM_EMAIL=noreply@ventia.pe

# Firebase Admin SDK (for FCM push notifications)
# Get from: Firebase Console > Project Settings > Service accounts > Generate new private key
# Extract these 3 values from the downloaded JSON file
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
