# Rails Environment
RAILS_ENV=development
SECRET_KEY_BASE=your-secret-key-here-generate-with-rails-secret

# Database Configuration
# Para Docker: usa "postgres" como host
# Para local: usa "localhost" o "host.docker.internal"
POSTGRES_HOST=postgres
POSTGRES_PORT=5433  # Puerto externo (mapea a 5432 en el contenedor)
POSTGRES_PORT_INTERNAL=5432  # Puerto interno del contenedor
POSTGRES_DATABASE=messaging_db
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=messaging_password

# Redis Configuration (for Sidekiq and caching)
REDIS_PORT=6380  # Puerto externo (mapea a 6379 en el contenedor)
REDIS_URL=redis://redis:6379/1

# Server Configuration
MESSAGING_SERVICE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Internal service-to-service auth — debe coincidir con apps/backend/.env
# El backend FastAPI lo envía en header X-API-Key en cada request interna.
# Generar con: openssl rand -hex 32
MESSAGING_SERVICE_API_KEY=your_messaging_service_api_key_here

# Facebook / WhatsApp Cloud API
# Get these from Meta for Developers: https://developers.facebook.com
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# WhatsApp Cloud API
# These are stored per-tenant in the database, not here
# This is just for reference
# WHATSAPP_CLOUD_BASE_URL=https://graph.facebook.com

# Logging
LOG_LEVEL=info
RAILS_LOG_TO_STDOUT=true

# Sentry (Error Monitoring — leave empty to disable)
SENTRY_DSN=

# Firebase Admin SDK (for FCM push notifications)
# Get from: Firebase Console > Project Settings > Service accounts > Generate new private key
# Extract these 3 values from the downloaded JSON file
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
